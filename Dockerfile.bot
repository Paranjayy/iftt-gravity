FROM oven/bun:1-alpine
WORKDIR /app

# Copy package files
COPY package.json bun.lock* ./
RUN bun install --frozen-lockfile

# Copy source (bot only needs src/lib)
COPY src/ ./src/
COPY tsconfig.json ./

# Config will be mounted via Railway env vars / volume
# Start the bot with --watch for auto-reload on code change
CMD ["bun", "--watch", "src/lib/bot.ts"]
