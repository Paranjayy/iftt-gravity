{
  "$schema": "https://www.raycast.com/schemas/extension.json",
  "name": "gravity-hub",
  "version": "1.1.3",
  "title": "Gravity Hub",
  "description": "Native Mission Control for the Gravity IoT Hub.",
  "icon": "assets/icon.png",
  "author": "paranjay",
  "license": "MIT",
  "commands": [
    {
      "name": "control",
      "title": "Control House",
      "description": "Manage AC, Lights, and Scenes",
      "icon": "assets/icon.png",
      "mode": "view"
    },
    {
      "name": "logs",
      "title": "View Logs",
      "description": "See the latest house activity",
      "icon": "assets/icon.png",
      "mode": "view"
    },
    {
      "name": "archive",
      "title": "Search Clipboard Archive",
      "description": "Infinite history of your copies and cuts",
      "icon": "assets/icon.png",
      "mode": "view"
    },
    {
      "name": "stats",
      "title": "Hub Dashboard",
      "description": "Real-time energy and system health",
      "icon": "assets/icon.png",
      "mode": "view"
    },
    {
      "name": "cortex",
      "title": "Gravity Cortex",
      "description": "Active intelligence and background tasks",
      "icon": "assets/icon.png",
      "mode": "view"
    },
    {
      "name": "aura_toggle",
      "title": "Toggle Media Aura",
      "description": "Toggle automatic music-light sync",
      "icon": "assets/icon.png",
      "mode": "no-view"
    },
    {
      "name": "stack",
      "title": "Paste Stack (Sequence)",
      "description": "Manage and paste your queued clipboard items",
      "icon": "assets/icon.png",
      "mode": "view"
    },
    {
      "name": "jot",
      "title": "Gravity Jot (Notes)",
      "description": "Distraction-free vault notepad",
      "icon": "assets/icon.png",
      "mode": "view"
    },
    {
      "name": "notes",
      "title": "Gravity Notes (Type)",
      "description": "Infinite local notes with timestamps and Daily Note support",
      "icon": "assets/icon.png",
      "mode": "view"
    },
    {
      "name": "process-reaper",
      "title": "Process Reaper",
      "description": "Purge System Bloat & Heavy Apps",
      "icon": "assets/icon.png",
      "mode": "view"
    },
    {
      "name": "disk-analyzer",
      "title": "Disk Forge",
      "description": "DaisyDisk-style Storage Intelligence",
      "icon": "assets/icon.png",
      "mode": "view"
    },
    {
      "name": "git-probe",
      "title": "Git Project Probe",
      "description": "Probe & Group Git VCS Repositories",
      "icon": "assets/icon.png",
      "mode": "view"
    },
    {
      "name": "project-scaffolder",
      "title": "Workspace Scaffolder",
      "description": "Rapid Environment Hardening & Templates",
      "icon": "assets/icon.png",
      "mode": "view"
    },
    {
      "name": "node-reaper",
      "title": "Node Modules Reaper",
      "description": "Purge Redundant Dependencies & Save Space",
      "icon": "assets/icon.png",
      "mode": "view"
    },
    {
      "name": "convert-link",
      "title": "Convert URL to Markdown",
      "description": "Replace clipboard URL with a titled Markdown link",
      "icon": "assets/icon.png",
      "mode": "view"
    }
  ],
  "dependencies": {
    "@raycast/api": "^1.71.0",
    "node-fetch": "^3.3.2",
    "react": "18.2.0",
    "react-dom": "18.2.0"
  },
  "devDependencies": {
    "@types/node-fetch": "^2.6.9",
    "@raycast/eslint-config": "^1.0.8",
    "@types/node": "20.8.10",
    "@types/react": "18.2.27",
    "eslint": "^8.51.0",
    "prettier": "^3.0.3",
    "typescript": "^5.2.2"
  },
  "scripts": {
    "build": "ray build",
    "dev": "ray develop",
    "archive-only": "bun scripts/archive-brain.ts",
    "fix-lint": "eslint src --fix",
    "lint": "eslint src",
    "publish": "npx @raycast/api@latest publish"
  }
}
